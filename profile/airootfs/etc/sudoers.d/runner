# Allow harbor-deploy to receive KRB5_SECRETS_B64 from the runner environment.
# env_keep whitelists only this variable — SETENV: was avoided because it would
# allow the runner to inject arbitrary variables (LD_PRELOAD, PATH, BASH_ENV,
# etc.) into the root process, enabling code injection via child processes.
Defaults!/usr/local/sbin/harbor-deploy.sh env_keep+="KRB5_SECRETS_B64"
runner ALL=(root) NOPASSWD: /usr/local/sbin/harbor-deploy.sh
runner ALL=(root) NOPASSWD: /usr/local/sbin/harbor-compose-ctl.sh rescan
runner ALL=(root) NOPASSWD: /usr/local/sbin/harbor-compose-ctl.sh update
runner ALL=(root) NOPASSWD: /usr/local/sbin/harbor-compose-ctl.sh stop
runner ALL=(root) NOPASSWD: /usr/local/sbin/harbor-compose-ctl.sh start
