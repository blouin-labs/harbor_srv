# harbor-runner environment — written at deploy time by harbor-deploy.sh.
# This file documents the variables that end up in /etc/harbor-runner/.env
# on the live system. Do not commit actual values here.

# Runner org URL — fixed for blouin-labs.
ACTIONS_RUNNER_INPUT_URL=https://github.com/blouin-labs

# GitHub App ID for runner self-registration (not a secret — numeric, public).
# The matching private key is injected by harbor-deploy.sh as:
#   /etc/harbor-runner/runner-reg-key.pem  (bind-mounted into the container at
#   /run/secrets/runner-reg-key.pem)
# Store the App ID as vars.RUNNER_REG_APP_ID in the blouin-labs org.
RUNNER_REG_APP_ID=

# The gh-deploy SSH private key is also injected by harbor-deploy.sh as:
#   /etc/harbor-runner/gh-deploy-key  (bind-mounted at /run/secrets/gh-deploy-key)
# Store it as secrets.GH_DEPLOY_SSH_KEY (raw PEM, no base64) in the blouin-labs org.
# The matching public key must be in /var/lib/gh-deploy/.ssh/authorized_keys.
