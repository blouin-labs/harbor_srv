# Runner org URL — fixed for blouin-labs.
ACTIONS_RUNNER_INPUT_URL=https://github.com/blouin-labs

# Base64-encoded tar of .runner + .credentials + .credentials_rsaparams.
# Extract after initial registration:
#   docker exec harbor-runner \
#     tar -czC /home/runner .runner .credentials .credentials_rsaparams | base64 -w0
# Store as RUNNER_CREDS_B64 in the RUNNER_ENV_B64 org secret, then rebuild RUNNER_ENV_B64.
RUNNER_CREDS_B64=

# Base64-encoded gh-deploy private SSH key (no newlines):
#   base64 -w0 < /path/to/gh_deploy_key
# The matching public key must be in /var/lib/gh-deploy/.ssh/authorized_keys.
GH_DEPLOY_SSH_KEY_B64=
